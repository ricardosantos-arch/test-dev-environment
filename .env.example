# =============================================================================
# Proffer — Variáveis de Ambiente (Development)
# =============================================================================
# Copie este arquivo para .env.backend e .env.frontend
#
#   cp .env.example .env.backend
#   cp .env.example .env.frontend
#
# Os valores abaixo são para desenvolvimento LOCAL.
# Nunca use valores de produção aqui.
# =============================================================================

# --- PostgreSQL (local) ---
HOSTNAME_RDS=postgres
PORT_RDS=5432
USER_RDS=proffer_dev
PASSWORD_RDS=proffer_dev_2026
DBNAME_RDS=proffer

# --- MongoDB (local) ---
DOCDB_ENDPOINT=mongodb://proffer_dev:proffer_dev_2026@mongodb:27017/Proffer?authSource=admin
DOCDB_URI=mongodb://proffer_dev:proffer_dev_2026@mongodb:27017/?authSource=admin
DOCDB_USER=proffer_dev
DOCDB_PW=proffer_dev_2026

# --- Ambiente ---
ENVIRONMENT=development
DOMAIN_PROD=http://localhost:3000

# --- AWS Cognito (mock — usar moto ou valores de teste) ---
AWS_POOL_ID=us-east-2_MOCK_DEV
COGNITO_AWS_POOL_ID=us-east-2_MOCK_DEV
COGNITO_CLIENT_ID=mock-client-id-dev
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=MOCK_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=MOCK_SECRET_KEY

# --- Stripe (modo teste) ---
STRIPE_API_KEY=sk_test_mock
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_mock
ENDPOINT_SECRET=whsec_mock_dev

# --- HubSpot (desabilitado em dev) ---
HUBSPOT_ACCESS_TOKEN=mock-hubspot-token
HUBSPOT_TICKETS_URL=https://api.hubapi.com/crm/v3/objects/tickets/search

# --- GCP (projetos dev) ---
GCP_PROJECT_ID=proffer-api-dev
GCP_REGION=us-central1

# --- Frontend (Vite) ---
VITE_COGNITO_REGION=us-east-2
VITE_COGNITO_USER_POOL_ID=mock-pool-id
VITE_COGNITO_CLIENT_ID=mock-client-id
VITE_COGNITO_IDENTITY_POOL_ID=mock-identity-pool-id
VITE_API_URL=http://localhost:5000
VITE_PARCEIROS_API_URL=http://localhost:5001

# --- API Extrator ---
MONGO_DB=Proffer
COLLECTION_INFO=database-cliente
JWT_SECRET=dev-jwt-secret-proffer-2026
FIXED_JWT=dev-fixed-jwt-token
